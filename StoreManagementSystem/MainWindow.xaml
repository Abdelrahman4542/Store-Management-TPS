<Window x:Class="StoreManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Store Management System"
        Height="900"
        Width="1400">

    <Grid Background="#F1F5F9">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->

        <Border Background="#1E293B">

            <StackPanel Margin="15">

                <TextBlock Text="Dashboard"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="10"/>

                <Button Content="Inventory"
                        Height="40"
                        Margin="0 10"
                        Click="InventoryBtn_Click"/>

                <Button Content="Products"
                        Height="40"
                        Margin="0 10"
                        Click="ProductsBtn_Click"/>

                <Button Content="POS"
                        Height="40"
                        Margin="0 10"
                        Click="POSBtn_Click"/>

            </StackPanel>

        </Border>

        <!-- Content -->

        <ContentControl x:Name="MainContent"
                        Grid.Column="1"/>

    </Grid>
    

</Window>
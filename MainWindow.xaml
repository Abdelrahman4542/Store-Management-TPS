<Window x:Class="StoreManagementSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:StoreManagementSystem.ViewModels"
        mc:Ignorable="d"
        Title="Store Management System"
        WindowState="Maximized"
        Background="#F8FAFC">

    <Window.DataContext>
        <viewModels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>

        <Style TargetType="Button">

            <Setter Property="Height"
                    Value="45"/>

            <Setter Property="Padding"
                    Value="20,0"/>

            <Setter Property="FontSize"
                    Value="14"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Foreground"
                    Value="#334155"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                         Value="True">

                    <Setter Property="Background"
                            Value="#E2E8F0"/>

                </Trigger>

            </Style.Triggers>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="85"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <!-- ================= TOP NAVBAR ================= -->

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1">

            <Grid Margin="25,0">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="Auto"/>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <!-- LOGO -->

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Border Width="50"
                            Height="50"
                            CornerRadius="25"
                            Background="#2563EB">

                        <TextBlock Text="S"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Border>

                    <StackPanel Margin="12,0,0,0">

                        <TextBlock Text="SM-TPS"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>

                        <TextBlock Text="Store Management System"
                                   FontSize="12"
                                   Foreground="#64748B"/>

                    </StackPanel>

                </StackPanel>

                <!-- NAVIGATION -->

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Button Content="Dashboard"
                            Margin="5"
                            Command="{Binding OpenDashboardCommand}"/>

                    <Button Content="Inventory"
                            Margin="5"
                            Visibility="{Binding InventoryVisibility}"
                            Command="{Binding OpenInventoryCommand}"/>

                    <Button Content="Products"
                            Margin="5"
                            Visibility="{Binding ProductsVisibility}"
                            Command="{Binding OpenProductsCommand}"/>

                    <Button Content="POS Terminal"
                            Margin="5"
                            Command="{Binding OpenPOSCommand}"/>

                    <Button Content="Transactions"
                            Margin="5"
                            Command="{Binding OpenTransactionsCommand}"/>

                </StackPanel>

                <!-- LOGOUT -->

                <Button Grid.Column="2"
                        Content="Logout"
                        Width="120"
                        Height="45"
                        Background="#DC2626"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding LogoutCommand}"/>

            </Grid>

        </Border>

        <!-- ================= CONTENT ================= -->

        <Grid Grid.Row="1">

            <Border Margin="20"
                    Background="White"
                    CornerRadius="20">

                <ContentControl Content="{Binding CurrentView}"/>

            </Border>

        </Grid>

    </Grid>

</Window>
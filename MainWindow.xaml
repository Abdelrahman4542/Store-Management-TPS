<Window x:Class="StoreManagementSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:StoreManagementSystem.ViewModels"
        mc:Ignorable="d"
        Title="Store Management System"
    
        Background="#EEF2F7">

    <Window.DataContext>

        <viewModels:MainViewModel/>

    </Window.DataContext>

    <Grid>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="240"/>

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- ================= SIDEBAR ================= -->

        <Border Background="#0F172A" >

            <StackPanel>

                <!-- LOGO -->

                <Border Height="80"
                        Background="#111827">

                    <Grid>

                        <TextBlock Text="SM-TPS"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                    </Grid>

                </Border>

                <!-- MENU -->

                <StackPanel Margin="10 20 10 10">

                    <Button Content="Dashboard"
                            Height="45"
                            Margin="0 0 0 10"
                            Background="#374151"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Command="{Binding OpenDashboardCommand}"/>

                    <Button Content="Inventory"
                            Height="45"
                            Margin="0 0 0 10"
                            Background="#374151"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Visibility="{Binding InventoryVisibility}"
                            Command="{Binding OpenInventoryCommand}"/>

                    <Button Content="Products"
                            Height="45"
                            Margin="0 0 0 10"
                            Background="#374151"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Visibility="{Binding ProductsVisibility}"
                            Command="{Binding OpenProductsCommand}"/>

                    <Button Content="POS Terminal"
                            Height="45"
                            Margin="0 0 0 10"
                            Background="#374151"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Command="{Binding OpenPOSCommand}"/>

                    <Button Content="Transactions"
                            Height="45"
                            Margin="0 0 0 10"
                            Background="#374151"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Command="{Binding OpenTransactionsCommand}"/>

                    <Button Content="Logout"
                            Height="45"
                            Margin="0 40 0 0"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            Command="{Binding LogoutCommand}"/>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- ================= CONTENT ================= -->

        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"/>

    </Grid>

</Window>
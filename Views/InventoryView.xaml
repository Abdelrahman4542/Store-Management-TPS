<UserControl x:Class="StoreManagementSystem.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:StoreManagementSystem.ViewModels">

    <UserControl.DataContext>
        <viewModels:ProductViewModel/>
    </UserControl.DataContext>

    <Grid Background="#F8FAFC">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="25">

                <!-- HEADER -->

                <Border Background="#0F172A"
                        CornerRadius="20"
                        Padding="25"
                        Margin="0 0 0 20">

                    <StackPanel>

                        <TextBlock Text="Inventory Monitoring Center"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Track stock levels and inventory performance"
                                   Margin="0 8 0 0"
                                   Foreground="#CBD5E1"/>

                    </StackPanel>

                </Border>

                <!-- KPI CARDS -->

                <UniformGrid Columns="3"
                             Margin="0 0 0 20">

                    <Border Background="#2563EB"
                            CornerRadius="18"
                            Margin="8"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Total Products"
                                       Foreground="White"/>

                            <TextBlock Text="{Binding TotalProducts}"
                                       Foreground="White"
                                       FontSize="38"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                    <Border Background="#DC2626"
                            CornerRadius="18"
                            Margin="8"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Low Stock Items"
                                       Foreground="White"/>

                            <TextBlock Text="{Binding LowStockCount}"
                                       Foreground="White"
                                       FontSize="38"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                    <Border Background="#16A34A"
                            CornerRadius="18"
                            Margin="8"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Inventory Value"
                                       Foreground="White"/>

                            <TextBlock Text="{Binding InventoryValue,
                                       StringFormat={}{0:C}}"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- SEARCH -->

                <Border Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Margin="0 0 0 20">

                    <StackPanel>

                        <TextBlock Text="Search Inventory"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0 0 0 10"/>

                        <TextBox Height="42"
                                 FontSize="14"
                                 Padding="12"
                                 Text="{Binding SearchText,
                                 UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                </Border>

                <!-- TABLE -->

                <Border Background="White"
                        CornerRadius="18"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="Inventory Stock List"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0 0 0 15"/>

                        <DataGrid ItemsSource="{Binding Products}"
                                  SelectedItem="{Binding SelectedProduct}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  RowHeight="45"
                                  GridLinesVisibility="Horizontal">

                            <DataGrid.ColumnHeaderStyle>

                                <Style TargetType="DataGridColumnHeader">

                                    <Setter Property="Background"
                                            Value="#0F172A"/>

                                    <Setter Property="Foreground"
                                            Value="White"/>

                                    <Setter Property="FontWeight"
                                            Value="Bold"/>

                                    <Setter Property="Height"
                                            Value="40"/>

                                </Style>

                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Product Name"
                                                    Binding="{Binding Name}"
                                                    Width="2*"/>

                                <DataGridTextColumn Header="SKU"
                                                    Binding="{Binding SKU}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Price"
                                                    Binding="{Binding Price,
                                                    StringFormat={}{0:C}}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Stock Quantity"
                                                    Binding="{Binding StockQuantity}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Inventory Value"
                                                    Binding="{Binding TotalValue,
                                                    StringFormat={}{0:C}}"
                                                    Width="*"/>

                            </DataGrid.Columns>

                            <DataGrid.RowStyle>

                                <Style TargetType="DataGridRow">

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding IsLowStock}"
                                                     Value="True">

                                            <Setter Property="Background"
                                                    Value="#FEE2E2"/>

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </DataGrid.RowStyle>

                        </DataGrid>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>
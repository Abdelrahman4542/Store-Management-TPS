<UserControl x:Class="StoreManagementSystem.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:StoreManagementSystem.ViewModels">

    <UserControl.DataContext>
        <viewModels:POSViewModel/>
    </UserControl.DataContext>

    <Grid Background="#F8FAFC">

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="2.3*"/>

            <ColumnDefinition Width="1.2*"/>

        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->

        <Border Grid.Column="0"
                Margin="20"
                Background="White"
                CornerRadius="20"
                Padding="20">

            <StackPanel>

                <TextBlock Text="Point Of Sale Terminal"
                           FontSize="30"
                           FontWeight="Bold"/>

                <TextBlock Text="Search products and create transactions"
                           Foreground="Gray"
                           Margin="0 5 0 20"/>

                <TextBox Height="45"
                         FontSize="15"
                         Padding="12"
                         Margin="0 0 0 20"
                         Text="{Binding SearchText,
                         UpdateSourceTrigger=PropertyChanged}"/>

                <DataGrid ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          RowHeight="45"
                          GridLinesVisibility="Horizontal">

                    <DataGrid.ColumnHeaderStyle>

                        <Style TargetType="DataGridColumnHeader">

                            <Setter Property="Background"
                                    Value="#0F172A"/>

                            <Setter Property="Foreground"
                                    Value="White"/>

                            <Setter Property="FontWeight"
                                    Value="Bold"/>

                            <Setter Property="Height"
                                    Value="40"/>

                        </Style>

                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Product"
                                            Binding="{Binding Name}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price,
                                            StringFormat={}{0:C}}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Stock"
                                            Binding="{Binding StockQuantity}"
                                            Width="*"/>

                    </DataGrid.Columns>

                    <DataGrid.RowStyle>

                        <Style TargetType="DataGridRow">

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsLowStock}"
                                             Value="True">

                                    <Setter Property="Background"
                                            Value="#FEE2E2"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </DataGrid.RowStyle>

                </DataGrid>

                <Button Content="ADD TO CART"
                        Height="50"
                        Margin="0 20 0 0"
                        FontWeight="Bold"
                        FontSize="15"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding AddToCartCommand}"/>

            </StackPanel>

        </Border>

        <!-- RIGHT SIDE -->

        <Border Grid.Column="1"
                Margin="20"
                Background="#0F172A"
                CornerRadius="20"
                Padding="20">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- HEADER -->

                <StackPanel Grid.Row="0">

                    <TextBlock Text="Current Cart"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Customer Order"
                               Foreground="#CBD5E1"
                               Margin="0 5 0 20"/>

                </StackPanel>

                <!-- CART TABLE -->

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding CartItems}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Background="White"
                          BorderThickness="0"
                          Margin="0 0 0 15">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Item"
                                            Binding="{Binding Product.Name}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Qty"
                                            Binding="{Binding Quantity}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Total"
                                            Binding="{Binding LineTotal,
                                            StringFormat={}{0:C}}"
                                            Width="*"/>

                        <DataGridTemplateColumn Header=""
                                                Width="50">

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <Button Content="✖"
                                            Width="30"
                                            Height="30"
                                            Background="#DC2626"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.RemoveFromCartCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- TOTALS -->

                <Border Grid.Row="2"
                        Padding="15"
                        CornerRadius="15"
                        Background="#111827"
                        Margin="0 0 0 15">

                    <StackPanel>

                        <DockPanel Margin="0 5">

                            <TextBlock Text="Subtotal"
                                       Foreground="White"/>

                            <TextBlock Text="{Binding SubTotal,
                                       StringFormat={}{0:C}}"
                                       Foreground="White"/>

                        </DockPanel>

                        <DockPanel Margin="0 5">

                            <TextBlock Text="VAT"
                                       Foreground="White"/>

                            <TextBlock Text="{Binding VAT,
                                       StringFormat={}{0:C}}"
                                       Foreground="White"/>

                        </DockPanel>

                        <Separator Margin="0 10"/>

                        <DockPanel>

                            <TextBlock Text="TOTAL"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       Foreground="White"/>

                            <TextBlock Text="{Binding FinalTotal,
                                       StringFormat={}{0:C}}"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       Foreground="#4ADE80"/>

                        </DockPanel>

                    </StackPanel>

                </Border>

                <!-- CHECKOUT -->

                <Button Grid.Row="3"
                        Content="COMPLETE CHECKOUT"
                        Height="60"
                        FontWeight="Bold"
                        FontSize="18"
                        Background="#16A34A"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding CheckoutCommand}"/>

            </Grid>

        </Border>

    </Grid>

</UserControl>
<UserControl x:Class="StoreManagementSystem.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F1F5F9">

        <Grid.ColumnDefinitions>

            <!-- Products -->

            <ColumnDefinition Width="2*"/>

            <!-- Cart -->

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->

        <StackPanel Margin="20">

            <!-- Header -->

            <TextBlock Text="Sales Terminal"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <!-- Search -->

            <TextBox Width="300"
                     Height="40"
                     Margin="0 0 0 20"
                     FontSize="14"
                     Padding="10"
                     Text="{Binding SearchText,
                     UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Products -->

            <DataGrid ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      RowHeight="45"
                      FontSize="14"
                      HeadersVisibility="Column">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Product"
                                        Binding="{Binding Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Price"
                                        Binding="{Binding Price}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Stock"
                                        Binding="{Binding StockQuantity}"
                                        Width="*"/>

                </DataGrid.Columns>

            </DataGrid>

            <!-- Add To Cart -->

            <Button Content="Add To Cart"
                    Height="45"
                    Margin="0 20 0 0"
                    Background="#2563EB"
                    Foreground="White"
                    FontWeight="Bold"
                    Command="{Binding AddToCartCommand}"/>

        </StackPanel>

        <!-- RIGHT SIDE -->

        <Border Grid.Column="1"
                Background="White"
                Margin="20"
                CornerRadius="12"
                Padding="20">

            <StackPanel>

                <TextBlock Text="Current Cart"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0 0 0 20"/>

                <!-- Cart Items -->

                <DataGrid ItemsSource="{Binding CartItems}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Height="350">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Product"
                                            Binding="{Binding Name}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price}"
                                            Width="*"/>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- Totals -->

                <StackPanel Margin="0 20 0 0">

                    <TextBlock Text="{Binding SubTotal,
                    StringFormat=Subtotal: {0:C}}"
                               FontSize="16"
                               Margin="0 5"/>

                    <TextBlock Text="{Binding VAT,
                    StringFormat=VAT: {0:C}}"
                               FontSize="16"
                               Margin="0 5"/>

                    <TextBlock Text="{Binding FinalTotal,
                    StringFormat=Total: {0:C}}"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0 10"/>

                </StackPanel>

                <!-- Checkout -->

                <Button Content="Checkout"
                        Height="50"
                        Margin="0 20 0 0"
                        Background="#16A34A"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="16"
                        Command="{Binding CheckoutCommand}"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>
<UserControl x:Class="StoreManagementSystem.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:StoreManagementSystem.ViewModels">

    <!-- ================= DATACONTEXT ================= -->

    <UserControl.DataContext>
        <viewModels:ProductViewModel/>
    </UserControl.DataContext>

    <!-- ================= UI ================= -->

    <Grid Background="#F1F5F9">

        <StackPanel Margin="25">

            <!-- ================= HEADER ================= -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="25"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Products Management"
                               FontSize="28"
                               FontWeight="Bold"/>

                    <TextBlock Text="Manage products information"
                               Foreground="Gray"
                               Margin="0 8 0 0"/>

                </StackPanel>

            </Border>

            <!-- ================= FORM ================= -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="25"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Add / Edit Product"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0 0 0 20"/>

                    <WrapPanel>

                        <!-- PRODUCT NAME -->

                        <StackPanel Margin="10">

                            <TextBlock Text="Product Name"/>

                            <TextBox Width="180"
                                     Height="40"
                                     Padding="10"
                                     Text="{Binding SelectedProduct.Name,
                                     UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>

                        <!-- SKU -->

                        <StackPanel Margin="10">

                            <TextBlock Text="SKU"/>

                            <TextBox Width="180"
                                     Height="40"
                                     Padding="10"
                                     Text="{Binding SelectedProduct.SKU,
                                     UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>

                        <!-- PRICE -->

                        <StackPanel Margin="10">

                            <TextBlock Text="Price"/>

                            <TextBox Width="180"
                                     Height="40"
                                     Padding="10"
                                     Text="{Binding SelectedProduct.Price,
                                     UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>

                        <!-- STOCK -->

                        <StackPanel Margin="10">

                            <TextBlock Text="Stock Quantity"/>

                            <TextBox Width="180"
                                     Height="40"
                                     Padding="10"
                                     Text="{Binding SelectedProduct.StockQuantity,
                                     UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>

                    </WrapPanel>

                    <!-- BUTTONS -->

                    <WrapPanel Margin="10">

                        <Button Content="Add Product"
                                Width="140"
                                Height="42"
                                Margin="5"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Command="{Binding AddCommand}"/>

                        <Button Content="Update Product"
                                Width="140"
                                Height="42"
                                Margin="5"
                                Background="#0F172A"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Command="{Binding UpdateCommand}"/>

                        <Button Content="Delete Product"
                                Width="140"
                                Height="42"
                                Margin="5"
                                Background="#DC2626"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Command="{Binding DeleteCommand}"/>

                    </WrapPanel>

                </StackPanel>

            </Border>

            <!-- ================= PRODUCTS TABLE ================= -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Products"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0 0 0 15"/>

                    <DataGrid ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              RowHeight="45"
                              FontSize="14"
                              GridLinesVisibility="None">

                        <!-- HEADER STYLE -->

                        <DataGrid.ColumnHeaderStyle>

                            <Style TargetType="DataGridColumnHeader">

                                <Setter Property="Background"
                                        Value="#1E293B"/>

                                <Setter Property="Foreground"
                                        Value="White"/>

                                <Setter Property="FontWeight"
                                        Value="Bold"/>

                                <Setter Property="Height"
                                        Value="40"/>

                            </Style>

                        </DataGrid.ColumnHeaderStyle>

                        <!-- COLUMNS -->

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Product Name"
                                                Binding="{Binding Name}"
                                                Width="2*"/>

                            <DataGridTextColumn Header="SKU"
                                                Binding="{Binding SKU}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Price"
                                                Binding="{Binding Price,
                                                StringFormat={}{0:C}}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Stock"
                                                Binding="{Binding StockQuantity}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Inventory Value"
                                                Binding="{Binding TotalValue,
                                                StringFormat={}{0:C}}"
                                                Width="*"/>

                        </DataGrid.Columns>

                        <!-- LOW STOCK ALERT -->

                        <DataGrid.RowStyle>

                            <Style TargetType="DataGridRow">

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsLowStock}"
                                                 Value="True">

                                        <Setter Property="Background"
                                                Value="#FECACA"/>

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </DataGrid.RowStyle>

                    </DataGrid>

                </StackPanel>

            </Border>

        </StackPanel>

    </Grid>

</UserControl>
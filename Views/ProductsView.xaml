<UserControl x:Class="StoreManagementSystem.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F1F5F9">

        <StackPanel Margin="25">

            <!-- Header -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="25"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Products Management"
                               FontSize="28"
                               FontWeight="Bold"/>

                    <TextBlock Text="Manage products information"
                               Foreground="Gray"
                               Margin="0 8 0 0"/>

                </StackPanel>

            </Border>

            <!-- Form -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="25"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="Add / Edit Product"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0 0 0 20"/>

                    <WrapPanel>

                        <StackPanel Margin="10">

                            <TextBlock Text="Product Name"/>

                            <TextBox Width="180"
                                     Height="35"
                                     Text="{Binding SelectedProduct.Name,
                                     UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>

                        <StackPanel Margin="10">

                            <TextBlock Text="SKU"/>

                            <TextBox Width="180"
                                     Height="35"
                                     Text="{Binding SelectedProduct.SKU}"/>

                        </StackPanel>

                        <StackPanel Margin="10">

                            <TextBlock Text="Price"/>

                            <TextBox Width="180"
                                     Height="35"
                                     Text="{Binding SelectedProduct.Price}"/>

                        </StackPanel>

                        <StackPanel Margin="10">

                            <TextBlock Text="Stock Quantity"/>

                            <TextBox Width="180"
                                     Height="35"
                                     Text="{Binding SelectedProduct.StockQuantity}"/>

                        </StackPanel>

                    </WrapPanel>

                    <WrapPanel Margin="10">

                        <Button Content="Add Product"
                                Width="130"
                                Height="40"
                                Margin="5"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding AddCommand}"/>

                        <Button Content="Update Product"
                                Width="130"
                                Height="40"
                                Margin="5"
                                Background="#0F172A"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding UpdateCommand}"/>

                        <Button Content="Delete Product"
                                Width="130"
                                Height="40"
                                Margin="5"
                                Background="#DC2626"
                                Foreground="White"
                                BorderThickness="0"
                                Command="{Binding DeleteCommand}"/>

                    </WrapPanel>

                </StackPanel>

            </Border>

            <!-- Products Table -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Products"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0 0 0 15"/>

                    <DataGrid ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              RowHeight="45"
                              FontSize="14"
                              GridLinesVisibility="None">

                        <DataGrid.ColumnHeaderStyle>

                            <Style TargetType="DataGridColumnHeader">

                                <Setter Property="Background"
                                        Value="#1E293B"/>

                                <Setter Property="Foreground"
                                        Value="White"/>

                                <Setter Property="FontWeight"
                                        Value="Bold"/>

                                <Setter Property="Height"
                                        Value="40"/>

                            </Style>

                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Product Name"
                                                Binding="{Binding Name}"
                                                Width="*"/>

                            <DataGridTextColumn Header="SKU"
                                                Binding="{Binding SKU}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Price"
                                                Binding="{Binding Price}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Stock"
                                                Binding="{Binding StockQuantity}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </Border>

        </StackPanel>

    </Grid>

</UserControl>
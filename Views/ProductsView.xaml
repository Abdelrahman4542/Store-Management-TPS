<UserControl x:Class="StoreManagementSystem.Views.ProductsView"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:viewModels="clr-namespace:StoreManagementSystem.ViewModels">

  
    <UserControl.DataContext>
        <viewModels:ProductViewModel/>
    </UserControl.DataContext>

    <Grid Background="#F8FAFC">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= PRODUCTS TABLE ================= -->

        <Border Grid.Column="0"
            Margin="20"
            Background="White"
            CornerRadius="20"
            Padding="20">

            <StackPanel>

                <TextBlock Text="Products Catalog"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0 0 0 15"/>

                <TextBlock Text="Select any product to edit"
                       Foreground="Gray"
                       Margin="0 0 0 20"/>

                <DataGrid ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="45">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"
                                Value="#0F172A"/>
                            <Setter Property="Foreground"
                                Value="White"/>
                            <Setter Property="FontWeight"
                                Value="Bold"/>
                            <Setter Property="Height"
                                Value="40"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Product"
                                        Binding="{Binding Name}"
                                        Width="2*"/>

                        <DataGridTextColumn Header="SKU"
                                        Binding="{Binding SKU}"
                                        Width="*"/>

                        <DataGridTextColumn Header="Price"
                                        Binding="{Binding Price,StringFormat={}{0:C}}"
                                        Width="*"/>

                        <DataGridTextColumn Header="Stock"
                                        Binding="{Binding StockQuantity}"
                                        Width="*"/>

                        <DataGridTextColumn Header="Threshold"
                                        Binding="{Binding LowStockThreshold}"
                                        Width="*"/>

                        <DataGridTextColumn Header="Value"
                                        Binding="{Binding TotalValue,StringFormat={}{0:C}}"
                                        Width="*"/>

                    </DataGrid.Columns>

                    <DataGrid.RowStyle>

                        <Style TargetType="DataGridRow">

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsLowStock}"
                                         Value="True">

                                    <Setter Property="Background"
                                        Value="#FEE2E2"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </DataGrid.RowStyle>

                </DataGrid>

            </StackPanel>

        </Border>

        <!-- ================= PRODUCT FORM ================= -->

        <Border Grid.Column="1"
            Margin="0 20 20 20"
            Background="White"
            CornerRadius="20"
            Padding="25">

            <ScrollViewer>

                <StackPanel>

                    <TextBlock Text="Product Details"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0 0 0 20"/>

                    <!-- NAME -->

                    <TextBlock Text="Product Name"
                           FontWeight="SemiBold"/>

                    <TextBox Height="42"
                         Margin="0 5 0 15"
                         Padding="10"
                         Text="{Binding SelectedProduct.Name,
                         UpdateSourceTrigger=PropertyChanged,
                         ValidatesOnDataErrors=True,
                         NotifyOnValidationError=True}" />

                    <!-- SKU -->

                    <TextBlock Text="SKU"
                           FontWeight="SemiBold"/>

                    <TextBox Height="42"
                         Margin="0 5 0 15"
                         Padding="10"
                         Text="{Binding SelectedProduct.SKU,
                         UpdateSourceTrigger=PropertyChanged,
                         ValidatesOnDataErrors=True,
                         NotifyOnValidationError=True}" />

                    <!-- PRICE -->

                    <TextBlock Text="Price"
                           FontWeight="SemiBold"/>

                    <TextBox Height="42"
                         Margin="0 5 0 15"
                         Padding="10"
                         Text="{Binding SelectedProduct.Price,
                         UpdateSourceTrigger=PropertyChanged,
                         ValidatesOnDataErrors=True,
                         NotifyOnValidationError=True}" />

                    <!-- STOCK -->

                    <TextBlock Text="Stock Quantity"
                           FontWeight="SemiBold"/>

                    <TextBox Height="42"
                         Margin="0 5 0 15"
                         Padding="10"
                         Text="{Binding SelectedProduct.StockQuantity,
                         UpdateSourceTrigger=PropertyChanged,
                         ValidatesOnDataErrors=True,
                         NotifyOnValidationError=True}" />

                    <!-- LOW STOCK THRESHOLD -->

                    <TextBlock Text="Low Stock Threshold"
                           FontWeight="SemiBold"/>

                    <TextBox Height="42"
                         Margin="0 5 0 25"
                         Padding="10"
                         Text="{Binding SelectedProduct.LowStockThreshold,
                         UpdateSourceTrigger=PropertyChanged,
                         ValidatesOnDataErrors=True,
                         NotifyOnValidationError=True}" />

                    <!-- ACTION BUTTONS -->

                    <Button Content="Add Product"
                        Height="45"
                        Margin="0 0 0 10"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Command="{Binding AddCommand}"/>

                    <Button Content="Update Product"
                        Height="45"
                        Margin="0 0 0 10"
                        Background="#0F172A"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Command="{Binding UpdateCommand}"/>

                    <Button Content="Delete Product"
                        Height="45"
                        Background="#DC2626"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Command="{Binding DeleteCommand}"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>


</UserControl>

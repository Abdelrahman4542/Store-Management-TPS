<Window x:Class="StoreManagementSystem.Views.TransactionHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StoreManagementSystem.ViewModels"
        Title="Transaction History"
        Height="850"
        Width="1500"
        Background="#F8FAFC"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:TransactionHistoryViewModel/>
    </Window.DataContext>

    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="25">

                <!-- HEADER -->

                <Border Background="#0F172A"
                        CornerRadius="20"
                        Padding="30">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock Text="Transaction History"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Audit and monitor all completed sales"
                                       Margin="0 8 0 0"
                                       Foreground="#CBD5E1"/>

                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="90"
                                Height="90"
                                CornerRadius="45"
                                Background="#1E293B">

                            <TextBlock Text="TPS"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                        </Border>

                    </Grid>

                </Border>

                <!-- KPI CARDS -->

                <UniformGrid Columns="2"
                             Margin="0 20">

                    <Border Background="White"
                            CornerRadius="15"
                            Margin="10"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Total Transactions"
                                       Foreground="Gray"/>

                            <TextBlock Text="{Binding TotalTransactions}"
                                       FontSize="36"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                    <Border Background="White"
                            CornerRadius="15"
                            Margin="10"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Total Revenue"
                                       Foreground="Gray"/>

                            <TextBlock Text="{Binding TotalRevenue,
                                       StringFormat={}{0:C}}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#16A34A"/>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- SEARCH + BUTTON -->

                <Border Background="White"
                        CornerRadius="20"
                        Padding="20"
                        Margin="0 0 0 20">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="45"
                                 FontSize="15"
                                 Padding="12"
                                 Margin="0 0 20 0"
                                 Text="{Binding SearchText,
                                 UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Column="1"
                                Content="View Details"
                                Height="45"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Command="{Binding ViewDetailsCommand}" />

                    </Grid>

                </Border>

                <!-- TABLE -->

                <Border Background="White"
                        CornerRadius="20"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="All Transactions"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0 0 0 20"/>

                        <DataGrid ItemsSource="{Binding Transactions}"
                                  SelectedItem="{Binding SelectedTransaction}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  Height="450"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal">

                            <DataGrid.ColumnHeaderStyle>

                                <Style TargetType="DataGridColumnHeader">

                                    <Setter Property="Background"
                                            Value="#0F172A"/>

                                    <Setter Property="Foreground"
                                            Value="White"/>

                                    <Setter Property="FontWeight"
                                            Value="Bold"/>

                                    <Setter Property="Height"
                                            Value="42"/>

                                </Style>

                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Invoice #"
                                                    Binding="{Binding TransactionId}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Date"
                                                    Binding="{Binding TransactionDate,
                                                    StringFormat={}{0:dd MMM yyyy HH:mm}}"
                                                    Width="2*"/>

                                <DataGridTextColumn Header="Items"
                                                    Binding="{Binding ItemCount}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Subtotal"
                                                    Binding="{Binding SubTotal,
                                                    StringFormat={}{0:C}}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="VAT"
                                                    Binding="{Binding VAT,
                                                    StringFormat={}{0:C}}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Final Total"
                                                    Binding="{Binding FinalTotal,
                                                    StringFormat={}{0:C}}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="*"/>

                            </DataGrid.Columns>

                            <DataGrid.RowStyle>

                                <Style TargetType="DataGridRow">

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding Status}"
                                                     Value="Refunded">

                                            <Setter Property="Background"
                                                    Value="#FEE2E2"/>

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </DataGrid.RowStyle>

                        </DataGrid>

                        <!-- EMPTY STATE -->

                        <TextBlock Text="No Transactions Found"
                                   HorizontalAlignment="Center"
                                   FontSize="18"
                                   Foreground="Gray"
                                   Margin="0 20 0 0">

                            <TextBlock.Style>

                                <Style TargetType="TextBlock">

                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding Transactions.Count}"
                                                     Value="0">

                                            <Setter Property="Visibility"
                                                    Value="Visible"/>

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </TextBlock.Style>

                        </TextBlock>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Window>
<UserControl x:Class="StoreManagementSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1200">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="140"/>
                <RowDefinition Height="140"/>
                <RowDefinition Height="350"/>
                <RowDefinition Height="350"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="20">

                <DockPanel>

                    <TextBlock Text="{Binding WelcomeMessage}"
                               FontSize="24"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                </DockPanel>

            </Border>

            <!-- KPI ROW 1 -->

            <UniformGrid Grid.Row="1"
                         Columns="3"
                         Margin="0 20 0 0">

                <Border Background="White"
                        CornerRadius="12"
                        Margin="10"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="Products"
                                   Foreground="Gray"/>

                        <TextBlock Text="{Binding ProductsCount}"
                                   FontSize="32"
                                   FontWeight="Bold"/>

                    </StackPanel>

                </Border>

                <Border Background="White"
                        CornerRadius="12"
                        Margin="10"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="Low Stock"
                                   Foreground="Gray"/>

                        <TextBlock Text="{Binding LowStockCount}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#DC2626"/>

                    </StackPanel>

                </Border>

                <Border Background="White"
                        CornerRadius="12"
                        Margin="10"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="Today Sales"
                                   Foreground="Gray"/>

                        <TextBlock Text="{Binding TodaySales}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#16A34A"/>

                    </StackPanel>

                </Border>

            </UniformGrid>

            <!-- KPI ROW 2 -->
            <UniformGrid Grid.Row="2"
             Columns="2"
             Margin="0 10 0 0"
             Visibility="{Binding RevenueVisibility}">

                <Border Background="White"
            CornerRadius="12"
            Margin="10"
            Padding="20">

                    <StackPanel>

                        <TextBlock Text="Monthly Revenue"
                       Foreground="Gray"/>

                        <TextBlock Text="{Binding MonthlyRevenue}"
                       FontSize="28"
                       FontWeight="Bold"/>

                    </StackPanel>

                </Border>

                <Border Background="White"
            CornerRadius="12"
            Margin="10"
            Padding="20">

                    <StackPanel>

                        <TextBlock Text="Growth"
                       Foreground="Gray"/>

                        <TextBlock Text="{Binding GrowthRate}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#2563EB"/>

                    </StackPanel>

                </Border>

            </UniformGrid>

            <!-- SALES CHART -->

            <Border Grid.Row="3"
                    Background="White"
                    CornerRadius="12"
                    Margin="10"
                    Padding="20"
                   Visibility="{Binding AnalyticsVisibility}" >

                <Grid>

                    <TextBlock Text="Weekly Sales Trend"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Top"/>

                    <Border Margin="0 40 0 0"
                            Background="#F8FAFC"
                            CornerRadius="10"
                            Padding="10">

                        <lvc:CartesianChart Series="{Binding SalesSeries}">

                            <lvc:CartesianChart.AxisX>

                                <lvc:AxesCollection>

                                    <lvc:Axis Labels="{Binding SalesLabels}"/>

                                </lvc:AxesCollection>

                            </lvc:CartesianChart.AxisX>

                        </lvc:CartesianChart>

                    </Border>

                </Grid>

            </Border>

            <!-- ANALYTICS -->

            <Grid Grid.Row="4"
                 Visibility="{Binding AnalyticsVisibility}" >

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <!-- Top Selling Products -->

                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="12"
                        Margin="10"
                        Padding="20">

                    <Grid>

                        <TextBlock Text="Top Selling Products"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Top"/>

                        <Border Margin="0 40 0 0"
                                Background="#F8FAFC"
                                CornerRadius="10"
                                Padding="10">

                            <lvc:CartesianChart Series="{Binding TopProductsSeries}">

                                <lvc:CartesianChart.AxisX>

                                    <lvc:AxesCollection>

                                        <lvc:Axis Labels="{Binding TopProductsLabels}"/>

                                    </lvc:AxesCollection>

                                </lvc:CartesianChart.AxisX>

                            </lvc:CartesianChart>

                        </Border>

                    </Grid>

                </Border>

                <!-- PIE CHART -->

                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="12"
                        Margin="10"
                        Padding="20">

                    <Grid>

                        <TextBlock Text="Inventory Distribution"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Top"/>

                        <Border Margin="0 40 0 0"
                                Background="#F8FAFC"
                                CornerRadius="10"
                                Padding="10">

                            <lvc:PieChart
                                Series="{Binding InventorySeries}"
                                LegendLocation="Right"/>

                        </Border>

                    </Grid>

                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>

</UserControl>
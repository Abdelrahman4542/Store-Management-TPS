<Window x:Class="StoreManagementSystem.Views.TransactionDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transaction Details"
       
        Background="#F1F5F9">

    <Grid>

        <StackPanel Margin="25">

            <!-- ================= HEADER ================= -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="25"
                    Margin="0 0 0 20">

                <StackPanel>

                    <TextBlock Text="{Binding CurrentTransaction.TransactionId,
                               StringFormat=Transaction \#{0}}"
                               FontSize="28"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding CurrentTransaction.TransactionDate,
                               StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                               Foreground="Gray"
                               Margin="0 8 0 0"/>

                </StackPanel>

            </Border>

            <!-- ================= STATS ================= -->

            <WrapPanel Margin="0 0 0 20">

                <!-- ITEMS -->

                <Border Background="White"
                        Width="220"
                        Height="100"
                        CornerRadius="10"
                        Margin="0 0 20 0"
                        Padding="15">

                    <StackPanel>

                        <TextBlock Text="Items"
                                   Foreground="Gray"/>

                        <TextBlock Text="{Binding CurrentTransaction.ItemCount}"
                                   FontSize="36"
                                   FontWeight="Bold"/>

                    </StackPanel>

                </Border>

                <!-- STATUS -->

                <Border Background="White"
                        Width="220"
                        Height="100"
                        CornerRadius="10"
                        Margin="0 0 20 0"
                        Padding="15">

                    <StackPanel>

                        <TextBlock Text="Status"
                                   Foreground="Gray"/>

                        <TextBlock Text="{Binding CurrentTransaction.Status}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#2563EB"/>

                    </StackPanel>

                </Border>

                <!-- TOTAL -->

                <Border Background="White"
                        Width="220"
                        Height="100"
                        CornerRadius="10"
                        Padding="15">

                    <StackPanel>

                        <TextBlock Text="Total"
                                   Foreground="Gray"/>

                        <TextBlock Text="{Binding CurrentTransaction.FinalTotal,
                                   StringFormat={}{0:C}}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#16A34A"/>

                    </StackPanel>

                </Border>

            </WrapPanel>

            <!-- ================= ITEMS TABLE ================= -->

            <Border Background="White"
                    CornerRadius="12"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Transaction Items"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0 0 0 15"/>

                    <DataGrid ItemsSource="{Binding CurrentTransaction.Items}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              RowHeight="45"
                              FontSize="14"
                              GridLinesVisibility="None"
                              Height="320">

                        <!-- HEADER STYLE -->

                        <DataGrid.ColumnHeaderStyle>

                            <Style TargetType="DataGridColumnHeader">

                                <Setter Property="Background"
                                        Value="#1E293B"/>

                                <Setter Property="Foreground"
                                        Value="White"/>

                                <Setter Property="FontWeight"
                                        Value="Bold"/>

                                <Setter Property="Height"
                                        Value="40"/>

                            </Style>

                        </DataGrid.ColumnHeaderStyle>

                        <!-- COLUMNS -->

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Product"
                                                Binding="{Binding Name}"
                                                Width="2*"/>

                            <DataGridTextColumn Header="Quantity"
                                                Binding="{Binding Quantity}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Unit Price"
                                                Binding="{Binding UnitPrice,
                                                StringFormat={}{0:C}}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Line Total"
                                                Binding="{Binding LineTotal,
                                                StringFormat={}{0:C}}"
                                                Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <!-- ================= TOTALS ================= -->

                    <StackPanel Margin="0 20 0 0">

                        <TextBlock Text="{Binding CurrentTransaction.SubTotal,
                                   StringFormat=Subtotal: {0:C}}"
                                   FontSize="16"
                                   Margin="0 5"/>

                        <TextBlock Text="{Binding CurrentTransaction.VAT,
                                   StringFormat=VAT: {0:C}}"
                                   FontSize="16"
                                   Margin="0 5"/>

                        <TextBlock Text="{Binding CurrentTransaction.FinalTotal,
                                   StringFormat=Total: {0:C}}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0 10"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </StackPanel>

    </Grid>

</Window>
<Window x:Class="StoreManagementSystem.Views.TransactionDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transaction Details"
        Height="850"
        Width="1400"
        Background="#F8FAFC"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="25">

                <!-- HEADER -->

                <Border Background="#0F172A"
                        CornerRadius="20"
                        Padding="30">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock Text="Transaction Details"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="{Binding CurrentTransaction.TransactionId,
                                       StringFormat=Invoice \#{0}}"
                                       FontSize="18"
                                       Foreground="#CBD5E1"
                                       Margin="0 8 0 0"/>

                            <TextBlock Text="{Binding CurrentTransaction.TransactionDate,
                                       StringFormat={}{0:dd MMM yyyy - hh:mm tt}}"
                                       Foreground="#94A3B8"/>

                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="90"
                                Height="90"
                                CornerRadius="45"
                                Background="#1E293B">

                            <TextBlock Text="TPS"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                        </Border>

                    </Grid>

                </Border>

                <!-- KPI CARDS -->

                <UniformGrid Columns="3"
                             Margin="0 20 0 20">

                    <Border Background="White"
                            Margin="10"
                            CornerRadius="15"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Items Sold"
                                       Foreground="Gray"/>

                            <TextBlock Text="{Binding CurrentTransaction.ItemCount}"
                                       FontSize="36"
                                       FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                    <Border Background="White"
                            Margin="10"
                            CornerRadius="15"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Status"
                                       Foreground="Gray"/>

                            <TextBlock Text="{Binding CurrentTransaction.Status}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#2563EB"/>

                        </StackPanel>

                    </Border>

                    <Border Background="White"
                            Margin="10"
                            CornerRadius="15"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Final Total"
                                       Foreground="Gray"/>

                            <TextBlock Text="{Binding CurrentTransaction.FinalTotal,
                                       StringFormat={}{0:C}}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#16A34A"/>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <!-- ITEMS TABLE -->

                <Border Background="White"
                        CornerRadius="20"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="Purchased Items"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0 0 0 20"/>

                        <DataGrid ItemsSource="{Binding CurrentTransaction.Items}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  Height="350"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal">

                            <DataGrid.ColumnHeaderStyle>

                                <Style TargetType="DataGridColumnHeader">

                                    <Setter Property="Background"
                                            Value="#0F172A"/>

                                    <Setter Property="Foreground"
                                            Value="White"/>

                                    <Setter Property="FontWeight"
                                            Value="Bold"/>

                                    <Setter Property="Height"
                                            Value="42"/>

                                </Style>

                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Product"
                                                    Binding="{Binding ProductName}"
                                                    Width="2*"/>

                                <DataGridTextColumn Header="Quantity"
                                                    Binding="{Binding Quantity}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Unit Price"
                                                    Binding="{Binding UnitPrice,
                                                    StringFormat={}{0:C}}"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Line Total"
                                                    Binding="{Binding LineTotal,
                                                    StringFormat={}{0:C}}"
                                                    Width="*"/>

                            </DataGrid.Columns>

                        </DataGrid>

                        <!-- SUMMARY -->

                        <Border Margin="0 20 0 0"
                                Padding="20"
                                Background="#F8FAFC"
                                CornerRadius="15">

                            <StackPanel Width="300"
                                        HorizontalAlignment="Right">

                                <DockPanel Margin="0 5">

                                    <TextBlock Text="Subtotal"/>

                                    <TextBlock Text="{Binding CurrentTransaction.SubTotal,
                                               StringFormat={}{0:C}}"
                                               HorizontalAlignment="Right"/>

                                </DockPanel>

                                <DockPanel Margin="0 5">

                                    <TextBlock Text="VAT"/>

                                    <TextBlock Text="{Binding CurrentTransaction.VAT,
                                               StringFormat={}{0:C}}"
                                               HorizontalAlignment="Right"/>

                                </DockPanel>

                                <Separator Margin="0 10"/>

                                <DockPanel>

                                    <TextBlock Text="TOTAL"
                                               FontWeight="Bold"
                                               FontSize="20"/>

                                    <TextBlock Text="{Binding CurrentTransaction.FinalTotal,
                                               StringFormat={}{0:C}}"
                                               FontWeight="Bold"
                                               FontSize="20"
                                               Foreground="#16A34A"
                                               HorizontalAlignment="Right"/>

                                </DockPanel>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Window>